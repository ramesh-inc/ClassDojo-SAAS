	"item": [
		{
			"name": "Documentation",
			"item": [
				{
					"name": "Swagger UI Documentation",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// This will open the documentation in browser",
									"const baseUrl = pm.environment.get(\"base_url\");",
									"console.log(`📖 Open this URL in your browser: ${baseUrl}/api/docs/`);",
									"console.log(`📖 ReDoc documentation: ${baseUrl}/api/redoc/`);"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"protocolProfileBehavior": {
						"disableBodyPruning": true
					},
					"request": {
						"method": "GET",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "/** \n# API Documentation - Swagger UI\n\nInteractive API documentation with the ability to test endpoints directly.\n\n**Features:**\n- Browse all available endpoints\n- View request/response schemas\n- Test endpoints with live data\n- JWT authentication support\n\n**How to use:**\n1. Open this URL in your browser\n2. Click \"Authorize\" to add your JWT token\n3. Format: `Bearer {{access_token}}`\n4. Test any endpoint directly from the browser\n\n**/",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{base_url}}/api/docs/"
					},
					"response": [
						{
							"name": "Swagger UI Documentation",
							"originalRequest": {
								"method": "GET",
								"header": []
							},
							"_postman_previewlanguage": "",
							"header": [],
							"cookie": [],
							"body": ""
						}
					]
				}
			]
		},
